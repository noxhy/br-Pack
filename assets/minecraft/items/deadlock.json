{
  "model": {
    "type": "minecraft:select",
    "property": "minecraft:display_context",
    "cases": [
      {
        "when": ["head", "gui", "ground", "fixed", "on_shelf"],
        "model": {
          "type": "minecraft:model",
          "model": "minecraft:item/guns/deadlock/deadlock"
        }
      }
    ],
    "fallback": {
      "type": "minecraft:select",
      "property": "minecraft:custom_model_data",
      "cases": [
        {
          "when": ["equip"],
          "model": {
            "type": "minecraft:model",
            "model": "minecraft:item/guns/deadlock/deadlock_equip"
          }
        },
        {
          "when": ["reload"],
          "model": {
            "type": "minecraft:model",
            "model": "minecraft:item/guns/deadlock/deadlock_reload"
          }
        },
        {
          "when": ["firing"],
          "model": {
            "type": "minecraft:model",
            "model": "minecraft:item/guns/deadlock/deadlock_firing"
          }
        }
      ],
      "fallback": {
        "type": "minecraft:model",
        "model": "minecraft:item/guns/deadlock/deadlock"
      }
    }
  },
  "swap_animation_scale": 0,
  "hand_animation_on_swap": false
}